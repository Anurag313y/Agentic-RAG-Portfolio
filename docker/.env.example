# Optional env file for plain `docker run` (Compose uses repo-root `.dev.vars`).
#
#   copy docker\.env.example docker\.env
#   docker run --rm -p 127.0.0.1:8787:8787 --env-file docker/.env anurag-portfolio:local
#
# For Compose, copy the root example instead:
#   copy .dev.vars.example .dev.vars

ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=use-a-strong-password-here

# Contact form (SMTP — Gmail App Password recommended)
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# JARVIS voice + RAG (optional — can also set in Admin → API Configuration)
# DEEPGRAM_API_KEY=
# COHERE_API_KEY=
